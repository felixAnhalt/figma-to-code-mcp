{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "README.md",
    ".opencode/rules/typescript.md",
    ".opencode/rules/error-handling.md",
    ".opencode/rules/testing.md"
  ],
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push*": "ask",
      "git reset*": "ask",
      "git rebase*": "ask",
      "git commit --amend*": "ask",
      "rm -*": "ask",
      "npm publish*": "ask",
      "pnpm publish*": "ask",
      "gh pr create*": "ask",
      "gh pr merge*": "ask"
    },
    "webfetch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}
